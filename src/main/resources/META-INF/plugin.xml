<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.plugin.curl</id>
    <name>Curl Orchestrator</name>
    <version>1.0.1</version>
    <vendor email="support@bayazidsustami.com" url="https://www.bayazidsustami.com">Bayazid Sustami</vendor>

    <description><![CDATA[
      A powerful Postman-like HTTP client for Android Studio and IntelliJ IDEA, using Curl as the underlying engine.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="Curl Orchestrator" secondary="true" anchor="right" icon="AllIcons.General.Web"
                    factoryClass="com.plugin.curl.ui.CurlOrchestratorToolWindowFactory"/>
        <projectService serviceImplementation="com.plugin.curl.engine.CurlExecutorService"/>
        <applicationService serviceImplementation="com.plugin.curl.settings.CurlSettingsState"/>
        <applicationConfigurable parentId="tools" instance="com.plugin.curl.settings.CurlSettingsConfigurable"
                                 id="com.plugin.curl.settings.CurlSettingsConfigurable" displayName="Curl Orchestrator"/>
    </extensions>

    <actions>
        <action id="com.plugin.curl.actions.OpenCurlOrchestratorAction"
                class="com.plugin.curl.actions.OpenCurlOrchestratorAction"
                text="Open Curl Orchestrator"
                description="Opens the Curl Orchestrator Tool Window">
            <keyboard-shortcut keymap="$default" first-keystroke="shift ctrl C"/>
        </action>
    </actions>
</idea-plugin>
